# Build-time configuration. Copy to .env and fill in.
# .env is gitignored; this .example is committed for documentation.

# The default ingest endpoint baked into the SDK at build time.
# Customers consuming @scopeveil/sdk hit this URL by default; they
# can override with `new ScopeVeil({ endpoint: '...' })` if they
# self-host. The SDK's published dist contains this URL inline; the
# source tree does not.
SCOPEVEIL_DEFAULT_ENDPOINT=https://ingest.scopeveil.com
