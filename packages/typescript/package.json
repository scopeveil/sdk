{
  "name": "@scopeveil/sdk",
  "version": "0.3.2",
  "description": "Privacy-first cost & latency observability for LLM apps. The SDK ships only metadata: prompt content never leaves your process. Cost is computed server-side from raw tokens, clients never report dollar amounts.",
  "license": "MIT",
  "homepage": "https://scopeveil.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/scopeveil/sdk.git",
    "directory": "packages/typescript"
  },
  "bugs": {
    "url": "https://github.com/scopeveil/sdk/issues"
  },
  "keywords": [
    "llm",
    "openai",
    "anthropic",
    "observability",
    "cost",
    "latency",
    "privacy"
  ],
  "type": "module",
  "main": "./dist/cjs/index.js",
  "module": "./dist/esm/index.js",
  "types": "./dist/esm/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/esm/index.d.ts",
      "import": "./dist/esm/index.js",
      "require": "./dist/cjs/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prebuild": "node scripts/generate-defaults.mjs",
    "build": "tsc -p tsconfig.json && tsc -p tsconfig.cjs.json && node scripts/fixup-dist.mjs",
    "pretest": "node scripts/generate-defaults.mjs",
    "test": "vitest run --reporter verbose",
    "prepublishOnly": "npm run build"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
